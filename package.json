{
  "name": "@conferbot/react-native",
  "version": "1.0.0",
  "description": "Official React Native SDK for Conferbot - Native mobile chat widget for iOS and Android",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc --noEmit false",
    "watch": "tsc --watch --noEmit false",
    "clean": "rm -rf lib",
    "prepare": "npm run clean && npm run build",
    "test": "jest",
    "test:connection": "node tests/test-connection.js",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "conferbot",
    "react-native",
    "chat",
    "chatbot",
    "messaging",
    "customer-support",
    "mobile",
    "ios",
    "android"
  ],
  "author": "Conferbot <support@conferbot.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/conferbot/react-native-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/conferbot/react-native-sdk/issues"
  },
  "homepage": "https://docs.conferbot.com/mobile/react-native",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-native": {
      "optional": false
    }
  },
  "dependencies": {
    "socket.io-client": "^4.7.2",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
